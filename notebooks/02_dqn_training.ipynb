 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 2 — DQN Training with Checkpoints\n",
    "\n",
    "Trains DQN on `ALE/Pong-v5` with automatic checkpoint saving every 100k steps and evaluation every 50k steps."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    from google.colab import drive\n",
    "    drive.mount('/content/drive')\n",
    "    SAVE_DIR = '/content/drive/MyDrive/RL_Models'\n",
    "except ImportError:\n",
    "    SAVE_DIR = 'models'\n",
    "\n",
    "import os\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import gymnasium as gym\n",
    "import ale_py\n",
    "from stable_baselines3 import DQN\n",
    "from stable_baselines3.common.env_util import make_atari_env\n",
    "from stable_baselines3.common.vec_env import VecFrameStack\n",
    "from stable_baselines3.common.callbacks import CheckpointCallback, EvalCallback\n",
    "\n",
    "gym.register_envs(ale_py)\n",
    "\n",
    "ENV_ID   = 'ALE/Pong-v5'\n",
    "RUN_NAME = 'dqn_pong_default'\n",
    "TOTAL_TIMESTEPS = 2_000_000"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "vec_env  = make_atari_env(ENV_ID, n_envs=1, seed=42)\n",
    "vec_env  = VecFrameStack(vec_env, n_stack=4)\n",
    "\n",
    "eval_env = make_atari_env(ENV_ID, n_envs=1, seed=0)\n",
    "eval_env = VecFrameStack(eval_env, n_stack=4)\n",
    "\n",
    "run_dir = os.path.join(SAVE_DIR, RUN_NAME)\n",
    "\n",
    "checkpoint_cb = CheckpointCallback(\n",
    "    save_freq=100_000,\n",
    "    save_path=run_dir,\n",
    "    name_prefix='dqn',\n",
    ")\n",
    "eval_cb = EvalCallback(\n",
    "    eval_env,\n",
    "    best_model_save_path=os.path.join(run_dir, 'best'),\n",
    "    log_path=os.path.join(run_dir, 'eval_logs'),\n",
    "    eval_freq=50_000,\n",
    "    n_eval_episodes=20,\n",
    "    deterministic=True,\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = DQN(\n",
    "    'CnnPolicy', vec_env,\n",
    "    learning_rate=1e-4,\n",
    "    batch_size=32,\n",
    "    buffer_size=100_000,\n",
    "    gamma=0.99,\n",
    "    target_update_interval=1000,\n",
    "    exploration_fraction=0.1,\n",
    "    exploration_final_eps=0.01,\n",
    "    train_freq=4,\n",
    "    tensorboard_log=os.path.join(SAVE_DIR, 'tensorboard'),\n",
    "    verbose=1,\n",
    ")\n",
    "\n",
    "model.learn(\n",
    "    total_timesteps=TOTAL_TIMESTEPS,\n",
    "    callback=[checkpoint_cb, eval_cb],\n",
    "    tb_log_name=RUN_NAME,\n",
    ")\n",
    "\n",
    "model.save(os.path.join(run_dir, 'dqn_final'))\n",
    "print('Done!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# List saved checkpoints\n",
    "import glob\n",
    "ckpts = sorted(glob.glob(os.path.join(run_dir, 'dqn_*.zip')))\n",
    "print(f'Saved checkpoints ({len(ckpts)}):')\n",
    "for c in ckpts:\n",
    "    print(' ', c)"
   ]
  }
 ],
